{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "g++ build",
      "type": "cppbuild",
      "command": "g++",
      "args": [
        "${file}",
        "-D_GLIBCXX_DEBUG",
        "-g", 
        "-I",
        "${workspaceFolder}",
        "-O2",
        "-std=c++23",
        "-Wall",
        "-Wextra",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
      }
    },
    {
      "label": "g++ delete .exe file",
      "type": "shell",
      "command": "Remove-Item ${fileDirname}/${fileBasenameNoExtension}.exe",
      "presentation": {
        "close": true
      },
    },
    {
      "label": "bundle current file",
      "type": "shell",
      "command": "oj-bundle ${file} -I ${workspaceFolder} > submit.cpp; (Get-Content submit.cpp) -replace '^#line.+?$', '' -replace '(cerr|std::cerr).+?;', ';' | Set-Content submit.cpp; code submit.cpp",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "setup random test",
      "type": "shell",
      "command": "Get-Content 'template/template.cpp' | Set-Content 'gen.cpp'; Get-Content 'template/template.cpp' | Set-Content 'ans.cpp'; Get-Content 'template/checker.cpp' | Set-Content 'che.cpp'; code gen.cpp ans.cpp che.cpp",
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "run random test (compare tokens)",
      "type": "shell",
      "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process; checker/judge.ps1 ${file} gen.cpp ans.cpp checker/wcmp.cpp",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "run random test (max error 1e-6)",
      "type": "shell",
      "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process; checker/judge.ps1 ${file} gen.cpp ans.cpp checker/rcmp6.cpp",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "run random test (max error 1e-9)",
      "type": "shell",
      "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process; checker/judge.ps1 ${file} gen.cpp ans.cpp checker/rcmp9.cpp",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "run random test (custom judge)",
      "type": "shell",
      "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process; checker/judge.ps1 ${file} gen.cpp ans.cpp che.cpp",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "run random test (interactive)",
      "type": "shell",
      "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process; checker/judge_interactive.ps1 ${file} gen.cpp",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "type": "cppbuild",
      "label": "C/C++: g++.exe build active file",
      "command": "C:/msys64/ucrt64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "C:/msys64/ucrt64/bin"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ]
}