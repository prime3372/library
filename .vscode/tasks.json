{
  "version": "2.0.0",
  "tasks": [
    // debug
    {
      "type": "cppbuild",
      "label": "g++.exe build active file",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "${file}",
        "-D_GLIBCXX_DEBUG",
        "-I",
        "${workspaceFolder}",
        "-O2",
        "-Wall",
        "-Wconversion",
        "-Wextra",
        "-Wfloat-equal",
        "-Wshadow",
        "-fdiagnostics-color=always",
        "-g",
        "-o",
        "${workspaceFolder}\\debug.exe",
        "-std=c++23"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true
      }
    },
    {
      "type": "shell",
      "label": "remove output file",
      "command": "if (Test-Path ${workspaceFolder}\\debug.exe) { Remove-Item ${workspaceFolder}\\debug.exe }",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "reveal": "never",
        "close": true
      },
      "problemMatcher": []
    },
    // oj-bundle
    {
      "type": "shell",
      "label": "bundle and copy",
      "command": "cmd /c oj-bundle ${file} -I ${workspaceFolder} > submit.cpp; (Get-Content submit.cpp) -replace '(cerr|std::cerr).+?;', ';' | Set-Clipboard; Remove-Item submit.cpp",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true
      }
    }
  ]
}