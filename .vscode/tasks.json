{
  "version": "2.0.0",
  "tasks": [
    // tasks for debug
    {
      "type": "cppbuild",
      "label": "g++.exe build active file",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "${file}",
        "-o",
        "${workspaceFolder}\\$debug.exe",
        "-D_GLIBCXX_DEBUG",
        "-I",
        "${workspaceFolder}",
        "-O2",
        "-Wall",
        "-Wextra",
        "-fdiagnostics-color=always",
        "-g",
        "-std=c++23"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true,
      }
    },
    {
      "type": "shell",
      "label": "remove output file",
      "command": "if (Test-Path ${workspaceFolder}\\debug.exe) { Remove-Item ${workspaceFolder}\\debug.exe }",
      "presentation": {
        "panel": "shared",
        "reveal": "never",
        "close": true
      },
      "problemMatcher": []
    },
    // tasks for oj-bundle
    {
      "type": "shell",
      "label": "bundle and copy",
      "command": "cmd /c oj-bundle ${file} -I ${workspaceFolder} > submit.cpp (Get-Content submit.cpp) -replace '(cerr|std::cerr).+?;', ';' | Set-Content submit.cpp; Get-Content submit.cpp | Set-Clipboard; if (Test-Path submit.cpp) { Remove-Item submit.cpp }",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "clear": true,
        "close": true
      }
    }
  ]
}